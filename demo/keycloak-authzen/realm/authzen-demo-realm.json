{
  "realm": "authzen-demo",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\"},{\"name\":\"email\"}],\"unmanagedAttributePolicy\":\"ENABLED\"}"
          ]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "a-client",
      "name": "A Client (deny: employee + dept A* + internet)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:9000/*"
      ],
      "webOrigins": [
        "+"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    },
    {
      "clientId": "b-client",
      "name": "B Client (deny: partner + internal)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:9000/*"
      ],
      "webOrigins": [
        "+"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Employee",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "attributes": {
        "user_type": [
          "employee"
        ],
        "department": [
          "A-Sales"
        ]
      }
    },
    {
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "email": "bob@example.com",
      "firstName": "Bob",
      "lastName": "Employee",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "attributes": {
        "user_type": [
          "employee"
        ],
        "department": [
          "B-Engineering"
        ]
      }
    },
    {
      "username": "carol",
      "enabled": true,
      "emailVerified": true,
      "email": "carol@example.com",
      "firstName": "Carol",
      "lastName": "Partner",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "attributes": {
        "user_type": [
          "partner"
        ],
        "department": [
          "Partner-Support"
        ]
      }
    }
  ],
  "authenticatorConfig": [
    {
      "alias": "authzen-config",
      "config": {
        "pdpUrl": "http://authzen-sidecar:9000",
        "action": "login",
        "resourceType": "Client",
        "failOpen": "false"
      }
    }
  ],
  "authenticationFlows": [
    {
      "alias": "browser-authzen",
      "description": "Browser flow that performs an AuthZEN access evaluation after password login",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "flowAlias": "browser-authzen-forms",
          "authenticatorFlow": true,
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "userSetupAllowed": false
        }
      ]
    },
    {
      "alias": "browser-authzen-forms",
      "description": "Username/password form followed by the AuthZEN access evaluation",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "authenticator": "authzen-access-evaluation",
          "authenticatorConfig": "authzen-config",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 20,
          "userSetupAllowed": false
        }
      ]
    }
  ],
  "browserFlow": "browser-authzen"
}
